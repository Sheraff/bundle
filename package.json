{
  "name": "bundle",
  "version": "1.0.0",
  "private": true,
  "description": "Research repo for bundle evolution work",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "stable-identity:build-fixtures": "node ./research/stable-identity/harness/build-fixtures.mjs",
    "stable-identity:inspect": "node ./research/stable-identity/harness/inspect-artifact.mjs",
    "stable-identity:inspect-treemap": "node ./research/stable-identity/harness/inspect-treemap.mjs",
    "stable-identity:test": "node ./research/stable-identity/harness/run-expectations.mjs",
    "stable-identity:refresh": "node ./research/stable-identity/harness/refresh.mjs",
    "contracts:typecheck": "pnpm --filter @workspace/contracts typecheck",
    "contracts:test": "pnpm --filter @workspace/contracts test",
    "contracts:check": "pnpm contracts:typecheck && pnpm contracts:test",
    "vite-plugin:build": "pnpm --filter @chunk-scope/vite-plugin build",
    "vite-plugin:typecheck": "pnpm --filter @chunk-scope/vite-plugin typecheck",
    "vite-plugin:test": "pnpm --filter @chunk-scope/vite-plugin test",
    "github-action:typecheck": "pnpm --filter @workspace/github-action typecheck",
    "github-action:test": "pnpm --filter @workspace/github-action test",
    "staging:build": "node ./scripts/staging-build.mjs",
    "staging:deploy": "node ./scripts/staging-deploy.mjs",
    "staging:verify": "node ./scripts/staging-verify.mjs",
    "web:typecheck": "pnpm --filter @workspace/web typecheck",
    "web:test": "pnpm --filter @workspace/web test",
    "web:test:unit": "pnpm --filter @workspace/web test:unit",
    "web:test:e2e": "pnpm --filter @workspace/web test:e2e",
    "web:seed": "pnpm --filter @workspace/web dev:seed",
    "research:test": "pnpm stable-identity:test"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "drizzle-kit": "0.31.10",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "typescript": "6.0.2",
    "valibot": "1.3.1",
    "vitest": "4.1.2",
    "wrangler": "4.85.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0"
}