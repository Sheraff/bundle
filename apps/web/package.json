{
  "name": "@workspace/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "generate-types": "wrangler types",
    "test": "vitest run --config vitest.config.mts",
    "test:unit": "vitest run --config vitest.unit.config.mts",
    "typecheck": "pnpm run generate-types && tsc --project tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local"
  },
  "dependencies": {
    "@workspace/contracts": "workspace:*",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.11",
    "ulid": "3.0.2",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.14.1"
  }
}
