{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "bundle-web-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "PUBLIC_APP_ORIGIN": "https://bundle.test",
    "GITHUB_APP_ID": "1",
    "GITHUB_APP_CLIENT_ID": "client-id",
    "GITHUB_APP_CLIENT_SECRET": "client-secret",
    "GITHUB_APP_SLUG": "bundle",
    "GITHUB_OIDC_AUDIENCE": "https://bundle.test",
    "GITHUB_WEBHOOK_SECRET": "test-webhook-secret",
    "SESSION_SIGNING_SECRET": "test-session-signing-secret",
    "AUTH_ENCRYPTION_KEY": "test-auth-encryption-key",
    "UPLOAD_TOKEN_SIGNING_SECRET": "test-upload-token-signing-secret",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bundle-web-test",
      "database_id": "00000000-0000-0000-0000-000000000000",
    },
  ],
  "r2_buckets": [
    {
      "binding": "RAW_UPLOADS_BUCKET",
      "bucket_name": "bundle-raw-uploads-test",
    },
    {
      "binding": "CACHE_BUCKET",
      "bucket_name": "bundle-cache-test",
    },
  ],
  "workflows": [
    {
      "name": "bundle-commit-group-settlement-test",
      "binding": "COMMIT_GROUP_SETTLEMENT_WORKFLOW",
      "class_name": "CommitGroupSettlementWorkflow",
    },
    {
      "name": "bundle-pr-publish-debounce-test",
      "binding": "PR_PUBLISH_DEBOUNCE_WORKFLOW",
      "class_name": "PrPublishDebounceWorkflow",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "NORMALIZE_RUN_QUEUE",
        "queue": "bundle-normalize-run-test",
      },
      {
        "binding": "DERIVE_RUN_QUEUE",
        "queue": "bundle-derive-run-test",
      },
      {
        "binding": "SCHEDULE_COMPARISONS_QUEUE",
        "queue": "bundle-schedule-comparisons-test",
      },
      {
        "binding": "MATERIALIZE_COMPARISON_QUEUE",
        "queue": "bundle-materialize-comparison-test",
      },
      {
        "binding": "REFRESH_SUMMARIES_QUEUE",
        "queue": "bundle-refresh-summaries-test",
      },
      {
        "binding": "PUBLISH_GITHUB_QUEUE",
        "queue": "bundle-publish-github-test",
      },
    ],
  },
}
